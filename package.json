{
  "name": "paperize",
  "productName": "paperize",
  "version": "1.0.11",
  "description": "Setting desktop wallpapers automatically",
  "main": "src/main.js",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint src --color"
  },
  "keywords": [],
  "author": "Fotis Fotopoulos SF",
  "license": "MIT",
  "config": {
    "forge": {
      "make_targets": {
        "win32": [
          "squirrel"
        ],
        "darwin": [
          "zip"
        ],
        "linux": [
          "deb",
          "rpm"
        ]
      },
      "electronPackagerConfig": {
        "packageManager": "npm",
        "arch": "ia32",
        "platform": "win32",
        "icon": "src/backEnd/icons/app-icon.ico",
        "asar": true
      },
      "electronWinstallerConfig": {
        "name": "paperize",
        "iconUrl": "file:///E:/Documents/ElectronJS/paperize/src/backEnd/icons/app-icon.ico",
        "setupIcon": "E:/Documents/ElectronJS/paperize/src/backEnd/icons/app-icon.ico"
      },
      "electronInstallerDebian": {},
      "electronInstallerRedhat": {},
      "github_repository": {
        "owner": "",
        "name": ""
      },
      "windowsStoreConfig": {
        "packageName": "",
        "name": "paperize_prebuilt"
      }
    }
  },
  "dependencies": {
    "auto-launch": "^5.0.5",
    "axios": "^0.18.0",
    "electron-compile": "^6.4.3",
    "electron-notify": "^0.1.0",
    "electron-settings": "^3.2.0",
    "electron-squirrel-startup": "^1.0.0",
    "request": "^2.87.0",
    "wallpaper": "^3.0.0"
  },
  "devDependencies": {
    "babel-plugin-transform-async-to-generator": "^6.24.1",
    "babel-preset-env": "^1.7.0",
    "babel-preset-react": "^6.24.1",
    "electron-forge": "^5.2.2",
    "electron-prebuilt-compile": "2.0.3",
    "eslint": "^3.19.0",
    "eslint-config-airbnb": "^15.1.0",
    "eslint-plugin-import": "^2.13.0",
    "eslint-plugin-jsx-a11y": "^5.1.1",
    "eslint-plugin-react": "^7.10.0"
  }
}
